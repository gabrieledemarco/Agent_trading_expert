# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# Trading provider (paper trading)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# LLM provider (research/synthesis)
OPENAI_API_KEY=sk-...

# Optional event bus alternative (if not using PostgreSQL LISTEN/NOTIFY)
REDIS_URL=redis://localhost:6379/0

# Runtime
PORT=8000
LOG_LEVEL=INFO
ENABLE_BACKGROUND_LOOPS=false
ENABLE_PIPELINE_AUTORUN=false
ENABLE_MONITORING_LOOP=false
ENABLE_TRADING_LOOP=false
V2_EVENT_DRIVEN=false
