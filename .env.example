# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# Trading provider (paper trading)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# LLM provider (Anthropic Claude — strategy builder + AI chat)
ANTHROPIC_API_KEY=sk-ant-...

# LLM provider (research/synthesis, optional fallback)
OPENAI_API_KEY=sk-...

# Monitoring alerts webhook (Slack, Discord, or any HTTP endpoint — optional)
ALERT_WEBHOOK_URL=
TRADING_ENV=paper

# Optional event bus alternative (if not using PostgreSQL LISTEN/NOTIFY)
REDIS_URL=redis://localhost:6379/0

# Runtime
PORT=8000
LOG_LEVEL=INFO
ENABLE_BACKGROUND_LOOPS=false
ENABLE_PIPELINE_AUTORUN=false
ENABLE_MONITORING_LOOP=false
ENABLE_TRADING_LOOP=false
V2_EVENT_DRIVEN=false
